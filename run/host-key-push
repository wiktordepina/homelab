#!/usr/bin/env bash
# Install a local public key into a homelab host's root authorized_keys.
# Bootstrap step: hosts (LXC or VM) are created with only worker_id_rsa.pub
# and root_pve_id_rsa.pub seeded, so your laptop key is not there yet.
# This routes via PVE (which DOES trust your laptop) and uses PVE's root
# key (which the host trusts) to push the laptop's pubkey on. Idempotent.
#
# Usage:
#   host-key-push <vmid> [pubkey-path]
#
# Default pubkey: ~/.ssh/id_ed25519.pub
#
# Examples:
#   host-key-push 206
#   host-key-push 214 ~/.ssh/id_rsa.pub
#
# Environment overrides:
#   PVE_USER   user on the Proxmox jump host (default: root)
#   PVE_HOST   IP of the Proxmox jump host   (default: 192.168.200.100)
#   HOST_USER  user inside the host          (default: root)

set -euo pipefail

PVE_USER="${PVE_USER:-root}"
PVE_HOST="${PVE_HOST:-192.168.200.100}"
HOST_USER="${HOST_USER:-root}"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() { sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'; }

if [[ $# -lt 1 || "$1" == "-h" || "$1" == "--help" ]]; then
  usage; exit 0
fi

command -v yq >/dev/null || { echo "host-key-push: yq not found in PATH" >&2; exit 1; }

vmid="$1"
pubkey="${2:-$HOME/.ssh/id_ed25519.pub}"

[[ -f "$pubkey" ]] || { echo "host-key-push: pubkey not found: $pubkey" >&2; exit 1; }

resolve_yaml() {
  local vmid="$1"
  local hits=()
  for dir in lxc vm; do
    [[ -f "$REPO_ROOT/config/$dir/$vmid.yaml" ]] && hits+=("$REPO_ROOT/config/$dir/$vmid.yaml")
  done
  if [[ ${#hits[@]} -eq 0 ]]; then
    echo "host-key-push: no config for VMID $vmid in config/lxc/ or config/vm/" >&2
    return 1
  fi
  if [[ ${#hits[@]} -gt 1 ]]; then
    echo "host-key-push: VMID $vmid declared in multiple places: ${hits[*]}" >&2
    return 1
  fi
  printf '%s' "${hits[0]}"
}

yaml="$(resolve_yaml "$vmid")"
cidr="$(yq -r '.terraform.ip_address' "$yaml")"
[[ -n "$cidr" && "$cidr" != "null" ]] || {
  echo "host-key-push: terraform.ip_address not found in $yaml" >&2; exit 1
}
ip="${cidr%%/*}"

# Base64-encode the pubkey so it survives word-splitting across two ssh hops.
# A space-separated arg (algo data comment) would be re-split by every remote
# shell along the way, losing everything after the first whitespace.
key_b64="$(base64 -w0 < "$pubkey")"

ssh "${PVE_USER}@${PVE_HOST}" bash -s -- "${HOST_USER}@${ip}" "$key_b64" <<'OUTER'
set -euo pipefail
target="$1"
key_b64="$2"
ssh -o StrictHostKeyChecking=accept-new "$target" bash -s -- "$key_b64" <<'INNER'
set -euo pipefail
key="$(printf '%s' "$1" | base64 -d)"
umask 077
mkdir -p ~/.ssh
chmod 700 ~/.ssh
touch ~/.ssh/authorized_keys
chmod 600 ~/.ssh/authorized_keys
if grep -qxF "$key" ~/.ssh/authorized_keys; then
  echo "key already present"
else
  if [ -s ~/.ssh/authorized_keys ] && [ "$(tail -c1 ~/.ssh/authorized_keys)" != "" ]; then
    printf '\n' >> ~/.ssh/authorized_keys
  fi
  printf '%s\n' "$key" >> ~/.ssh/authorized_keys
  echo "key installed"
fi
INNER
OUTER

echo "host-key-push: done — try ./run/host-ssh $vmid"
