#!/usr/bin/env bash
# SSH into a homelab LXC by VMID. Resolves the IP from config/lxc/<vmid>.yaml
# and connects directly. Bare IPs throughout so it works when homelab DNS is
# down. Run lxc-key-push <vmid> first if your laptop key isn't on the LXC yet.
#
# Usage:
#   lxc-ssh <vmid> [ssh-args | remote-command]
#
# Examples:
#   lxc-ssh 206
#   lxc-ssh 206 systemctl status docker
#   lxc-ssh 206 -L 8123:localhost:8123
#
# Environment overrides:
#   LXC_USER   user inside the LXC (default: root)

set -euo pipefail

LXC_USER="${LXC_USER:-root}"
LXC_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/config/lxc"

usage() { sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'; }

if [[ $# -lt 1 || "$1" == "-h" || "$1" == "--help" ]]; then
  usage; exit 0
fi

command -v yq >/dev/null || { echo "lxc-ssh: yq not found in PATH" >&2; exit 1; }

vmid="$1"; shift

yaml="$LXC_DIR/$vmid.yaml"
[[ -f "$yaml" ]] || { echo "lxc-ssh: no config for VMID $vmid at $yaml" >&2; exit 1; }

cidr="$(yq -r '.terraform.ip_address' "$yaml")"
[[ -n "$cidr" && "$cidr" != "null" ]] || {
  echo "lxc-ssh: terraform.ip_address not found in $yaml" >&2; exit 1
}
ip="${cidr%%/*}"

exec ssh -o StrictHostKeyChecking=accept-new "${LXC_USER}@${ip}" "$@"
