#!/usr/bin/env python3
"""
Generate an Ansible playbook for a Proxmox QEMU VM.

Usage:
  ./render_vm_playbook <vmid>

Reads ./config/vm/<vmid>.yaml and emits a playbook to stdout that targets the
VM by IP and applies the roles/tasks declared under the `ansible:` key. There
is no PVE-host preamble (VMs do not have an analog to LXC `pve_extra` — the
provider handles every per-VM Proxmox setting).

A `wait_for_connection` pre-task is always emitted because freshly created
VMs come back from `terraform apply` before cloud-init has finished bringing
up networking; without the wait, the first Ansible run gets `No route to
host` and the whole apply fails. Subsequent runs are no-ops because the
connection is already healthy.

Dependencies:
  - ruamel.yaml
"""


import sys
import ruamel.yaml as yaml

vmid = sys.argv[1]

# preserve_quotes keeps a source scalar's quoting through the round-trip. Without
# it ruamel emits under YAML 1.2 rules, dropping quotes it deems unnecessary —
# but ansible-playbook then re-reads under YAML 1.1, where an unquoted value like
# "23:00" is a sexagesimal number (23*60 = 1380). Holding the quotes keeps such
# strings (tariff window times, etc.) intact end to end. One instance must do both
# load and dump for the quote style to carry across.
yml = yaml.YAML()
yml.preserve_quotes = True

vm_conf_path = f'./config/vm/{vmid}.yaml'
with open(vm_conf_path) as conf_file:
  vm_conf = yml.load(conf_file)

vm_ip = vm_conf['terraform']['ip_address'].split('/')[0]
ansible_roles = vm_conf['ansible'].get('roles')
ansible_tasks = vm_conf['ansible'].get('tasks')

playbook = {
  'name': f'VM {vmid}',
  'hosts': vm_ip,
  'gather_facts': False,
  'pre_tasks': [
    {
      'name': 'Wait for SSH to come up after first boot',
      'ansible.builtin.wait_for_connection': {
        'timeout': 300,
        'sleep': 5,
      },
    },
    {
      'name': 'Gather facts',
      'ansible.builtin.setup': {},
    },
  ],
}

if ansible_roles:
  playbook.update({'roles': ansible_roles})

if ansible_tasks:
  playbook.update({'tasks': ansible_tasks})

yml.dump([playbook], sys.stdout)
