#!/usr/bin/env python3
"""
Generate an Ansible playbook for a Proxmox QEMU VM.

Usage:
  ./render_vm_playbook <vmid>

Reads ./config/vm/<vmid>.yaml and emits a playbook to stdout that targets the
VM by IP and applies the roles/tasks declared under the `ansible:` key. There
is no PVE-host preamble (VMs do not have an analog to LXC `pve_extra` — the
provider handles every per-VM Proxmox setting).

Dependencies:
  - ruamel.yaml
"""


import sys
import ruamel.yaml as yaml

vmid = sys.argv[1]

vm_conf_path = f'./config/vm/{vmid}.yaml'
with open(vm_conf_path) as conf_file:
  vm_conf = yaml.YAML().load(conf_file)

vm_ip = vm_conf['terraform']['ip_address'].split('/')[0]
ansible_roles = vm_conf['ansible'].get('roles')
ansible_tasks = vm_conf['ansible'].get('tasks')

playbook = {
  'name': f'VM {vmid}',
  'hosts': vm_ip
}

if ansible_roles:
  playbook.update({'roles': ansible_roles})

if ansible_tasks:
  playbook.update({'tasks': ansible_tasks})

yaml.YAML().dump([playbook], sys.stdout)
