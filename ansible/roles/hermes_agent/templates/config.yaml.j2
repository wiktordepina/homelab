{# Minimal Hermes config. Fields are guesses against the upstream schema and
   will need iteration once the daemon starts; cross-reference
   /opt/hermes-agent/docs/ on the LXC for the authoritative shape. #}
home: {{ hermes_home }}

server:
  host: 0.0.0.0
  gateway_port: {{ hermes_gateway_port }}
  dashboard_port: {{ hermes_dashboard_port }}

llm:
  provider: openai
  base_url: {{ hermes_litellm_endpoint }}
  model: {{ hermes_default_model }}
  api_key_env: HERMES_LITELLM_KEY

terminal:
  backend: docker

approval:
  mode: manual

logging:
  level: info

skills:
  autodiscover: true
