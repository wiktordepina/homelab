APP_NAME = Forgejo
RUN_USER = {{ forgejo_user }}
RUN_MODE = prod
WORK_PATH = {{ forgejo_data_dir }}

[server]
PROTOCOL = http
HTTP_ADDR = {{ forgejo_http_addr }}
HTTP_PORT = {{ forgejo_http_port }}
DOMAIN = {{ forgejo_domain }}
ROOT_URL = {{ forgejo_root_url }}
DISABLE_SSH = false
START_SSH_SERVER = true
SSH_LISTEN_HOST = {{ forgejo_ssh_addr }}
SSH_DOMAIN = {{ forgejo_domain }}
SSH_PORT = {{ forgejo_ssh_port }}
SSH_LISTEN_PORT = {{ forgejo_ssh_port }}
APP_DATA_PATH = {{ forgejo_data_dir }}/data
LFS_START_SERVER = true
OFFLINE_MODE = true

[lfs]
PATH = {{ forgejo_data_dir }}/data/lfs

[database]
DB_TYPE = sqlite3
PATH = {{ forgejo_data_dir }}/data/forgejo.db
LOG_SQL = false

[repository]
ROOT = {{ forgejo_data_dir }}/data/repositories
DEFAULT_PRIVATE = private
DEFAULT_PUSH_CREATE_PRIVATE = true

[security]
INSTALL_LOCK = true
PASSWORD_HASH_ALGO = argon2
MIN_PASSWORD_LENGTH = 12

[service]
DISABLE_REGISTRATION = {{ forgejo_disable_registration | string | lower }}
REQUIRE_SIGNIN_VIEW = true
ENABLE_NOTIFY_MAIL = false
DEFAULT_KEEP_EMAIL_PRIVATE = true
DEFAULT_ALLOW_CREATE_ORGANIZATION = true

[session]
PROVIDER = file
COOKIE_SECURE = true
COOKIE_NAME = forgejo_session

[log]
MODE = console
LEVEL = info
ROOT_PATH = {{ forgejo_log_dir }}

[metrics]
ENABLED = true

[ui]
DEFAULT_THEME = forgejo-auto

[picture]
DISABLE_GRAVATAR = true

[mailer]
ENABLED = false

[other]
SHOW_FOOTER_VERSION = true
SHOW_FOOTER_TEMPLATE_LOAD_TIME = false
